# ============================================================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE — copie para local/.env (fora do git) e
# preencha. O coletor lê com:  node --env-file=local/.env cron/sync.js
#
#   cp .env.example local/.env
#
# NÃO comite local/.env — ele está no .gitignore. Este arquivo (.env.example)
# só documenta QUAIS variáveis existem; nunca coloque segredos reais aqui.
# ============================================================================

# --- Riot Games API -----------------------------------------------------------
# Chave de desenvolvedor (https://developer.riotgames.com). Também é o secret
# RIOT_API_KEY do Worker (setado no dashboard da Cloudflare, não aqui).
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Cloudflare D1 (acesso via API HTTP usado pelo coletor) -------------------
# Account ID (dashboard da Cloudflare) e ID do banco D1.
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Token com permissão "D1: Edit" (Account API Tokens).
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Relatório da Tribo no Discord (cron/relatorio-discord.js) ----------------
# Webhook do canal onde o relatório é postado (obrigatório p/ postar de verdade).
DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxxxx/xxxxx
# Opcional: JSON { "NomeInvocador"|"puuid": "idDiscordParaMencao" }
# DISCORD_USER_MAP={"UGA Fulano":"123456789012345678"}

# ============================================================================
# TOGGLES DE RUNTIME (não são segredos — passe na linha de comando quando quiser)
# ============================================================================
# cron/sync.js e cron/backfill.js:
#   BACKFILL=1                 reprocessa TODO o histórico baixado (colunas novas)
#   PUUIDS="puuid1,puuid2"     roda só esses jogadores (ignora o filtro premium)
#
# cron/relatorio-discord.js:
#   PERIODO=dia|semana|mes|50|geral    janela de análise (default: dia)
#   FILA=solo|flex|ambas               qual ranqueada reportar (default: ambas)
#   PUUIDS="UGA"                       prefixo de nick / "Nome#Tag" / puuids
#   DRY_RUN=1                          imprime o relatório sem postar no Discord

# ============================================================================
# SECRETS DO WORKER (configurados na Cloudflare via `wrangler secret put`, NÃO
# neste arquivo — ficam só no Worker):
#   RIOT_API_KEY     -> proxy da Riot
#   ADMIN_PASSWORD   -> portão do painel Ancestralidade (SEM fallback no código:
#                       se não estiver setado, as rotas admin respondem 503)
# ============================================================================
